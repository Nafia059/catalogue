modules = ["nodejs-24"]
run = "pnpm --filter @workspace/api-server run dev"

[deployment]
run = "pnpm --filter @workspace/api-server run dev"
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["sh", "-c", "pnpm install --frozen-lockfile && pnpm --filter @workspace/api-server run build"]
env = { "CI" = "true" }

[nix]
channel = "stable-24_11"

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
