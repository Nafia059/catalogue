modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.run]
args = ["pnpm", "--filter", "@workspace/api-server", "run", "start"]

[deployment.postBuild]
args = ["pnpm", "--filter", "@workspace/api-server", "run", "build"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
